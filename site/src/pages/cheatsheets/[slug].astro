---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const sheets = await getCollection('cheatsheets');
  return sheets.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry }   = Astro.props;
const { Content } = await entry.render();
const d           = entry.data;
const base        = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title={`${d.title} · DSA Python`}
  description={d.description}
>
  <nav class="breadcrumb page-container" aria-label="Breadcrumb">
    <a href={`${base}/`}>Home</a>
    <span aria-hidden="true">›</span>
    <a href={`${base}/cheatsheets`}>Cheat Sheets</a>
    <span aria-hidden="true">›</span>
    <span aria-current="page">{d.title}</span>
  </nav>

  <div class="sheet-page page-container">

    <aside class="sheet-sidebar" aria-label="Cheat sheet info">
      <a href={`${base}/cheatsheets`} class="back-link">← Cheat Sheets</a>

      <div class="sidebar-section">
        <p class="sidebar-label">Category</p>
        <span class="category-chip">{d.category}</span>
      </div>

      {d.tags.length > 0 && (
        <div class="sidebar-section">
          <p class="sidebar-label">Tags</p>
          <div class="tag-list">
            {d.tags.map(t => <span class="tag">{t}</span>)}
          </div>
        </div>
      )}

      <div class="sidebar-section">
        <p class="sidebar-label">Description</p>
        <p class="sidebar-desc">{d.description}</p>
      </div>
    </aside>

    <article class="sheet-content prose">
      <h1>{d.title}</h1>
      <Content />
    </article>

  </div>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLPreElement>('.sheet-content pre').forEach(pre => {
    const btn = document.createElement('button');
    btn.className = 'copy-btn';
    btn.textContent = 'Copy';
    btn.setAttribute('aria-label', 'Copy code to clipboard');
    btn.addEventListener('click', async () => {
      const code = pre.querySelector('code')?.innerText ?? pre.innerText;
      await navigator.clipboard.writeText(code);
      btn.textContent = 'Copied!';
      btn.classList.add('copy-btn--done');
      setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copy-btn--done'); }, 2000);
    });
    pre.style.position = 'relative';
    pre.appendChild(btn);
  });
</script>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-top: 1.25rem;
    padding-bottom: 0.75rem;
    font-size: 0.8rem;
    color: var(--color-text-3);
    flex-wrap: wrap;
  }
  .breadcrumb a { color: var(--color-text-2); text-decoration: none; }
  .breadcrumb a:hover { color: var(--color-accent); }

  .sheet-page {
    display: grid;
    grid-template-columns: var(--sidebar-width) 1fr;
    gap: 2.5rem;
    padding-top: 1rem;
    padding-bottom: 4rem;
    align-items: start;
  }

  .sheet-sidebar {
    position: sticky;
    top: calc(var(--nav-height) + 1.25rem);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface-2);
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .back-link:hover {
    border-color: var(--color-accent);
    background: var(--color-accent-bg);
  }

  .sidebar-section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .sidebar-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-3);
    margin: 0;
  }
  .sidebar-desc {
    font-size: 0.8rem;
    color: var(--color-text-2);
    line-height: 1.6;
    margin: 0;
  }

  .category-chip {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    background: var(--color-accent-bg);
    border-radius: 999px;
    padding: 0.2em 0.7em;
  }

  .tag-list { display: flex; flex-wrap: wrap; gap: 0.375rem; }

  .sheet-content h1 {
    font-size: 1.6rem;
    margin-top: 0;
    margin-bottom: 0.75rem;
  }

  :global(.copy-btn) {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    font-size: 0.7rem;
    font-weight: 600;
    font-family: var(--font-sans, sans-serif);
    color: var(--color-text-2);
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0.2em 0.6em;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.15s ease, color 0.15s ease;
    z-index: 1;
  }
  :global(pre:hover .copy-btn), :global(.copy-btn:focus) { opacity: 1; }
  :global(.copy-btn--done) {
    opacity: 1;
    color: var(--color-easy) !important;
    border-color: var(--color-easy) !important;
  }

  @media (max-width: 900px) {
    .sheet-page { grid-template-columns: 1fr; }
    .sheet-sidebar {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 1rem;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      padding: 1rem 1.25rem;
    }
    .sidebar-desc { display: none; }
  }
</style>
