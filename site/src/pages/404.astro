---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Page Not Found · DSA Python"
  description="The page you're looking for doesn't exist."
  noindex={true}
>
  <div class="page-container not-found">
    <p class="not-found__code">404</p>
    <h1 class="not-found__title">Page not found</h1>
    <p class="not-found__desc">The page you're looking for doesn't exist or has been moved.</p>
    <div class="not-found__actions">
      <a href={`${base}/`} class="btn btn-primary">← Back to home</a>
      <a href={`${base}/topics`} class="btn btn-ghost">Browse topics</a>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-top: 5rem;
    padding-bottom: 6rem;
    gap: 1rem;
  }
  .not-found__code {
    font-size: 6rem;
    font-weight: 900;
    line-height: 1;
    color: var(--color-border-2);
    margin: 0;
    letter-spacing: -0.05em;
  }
  .not-found__title {
    font-size: 1.75rem;
    font-weight: 700;
    margin: 0;
  }
  .not-found__desc {
    color: var(--color-text-2);
    font-size: 1rem;
    margin: 0;
    max-width: 36ch;
  }
  .not-found__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }
</style>
