---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const base   = import.meta.env.BASE_URL.replace(/\/$/, '');
const topics = (await getCollection('topics')).sort((a, b) => a.data.order - b.data.order);
const total  = topics.reduce((sum, t) => sum + t.data.problemCount, 0);
---

<BaseLayout
  title="Topics · DSA Python"
  description="Browse all 17 DSA topic areas with 169 Python solutions covering arrays, graphs, trees, DP, and more."
>
  <div class="page-container" style="padding-top:2rem;padding-bottom:4rem;">

    <header class="topics-header">
      <h1>All Topics</h1>
      <p class="topics-sub">
        {topics.length} topic areas · {total} Python solutions
      </p>
    </header>

    <div class="topics-grid">
      {topics.map(t => {
        const d = t.data;
        return (
          <a href={`${base}/topics/${t.slug}`} class="topic-card" aria-label={`${d.title} — ${d.problemCount} problems`}>
            <div class="topic-card__header">
              <span class="topic-card__icon" aria-hidden="true">{d.icon}</span>
              <span class="topic-card__count">{d.problemCount}</span>
            </div>
            <h2 class="topic-card__name">{d.title}</h2>
            <p class="topic-card__desc">{d.description}</p>
            <div class="topic-card__badges">
              {d.easyCount   > 0 && <span class="badge badge-easy">{d.easyCount} E</span>}
              {d.mediumCount > 0 && <span class="badge badge-medium">{d.mediumCount} M</span>}
              {d.hardCount   > 0 && <span class="badge badge-hard">{d.hardCount} H</span>}
            </div>
            {d.patterns.length > 0 && (
              <div class="topic-card__patterns">
                {d.patterns.slice(0, 3).map(p => <span class="tag">{p}</span>)}
                {d.patterns.length > 3 && <span class="tag tag-extra">+{d.patterns.length - 3}</span>}
              </div>
            )}
          </a>
        );
      })}
    </div>

  </div>
</BaseLayout>

<style>
  .topics-header {
    margin-bottom: 2rem;
  }
  .topics-header h1 {
    font-size: 1.8rem;
    margin: 0 0 0.4rem;
  }
  .topics-sub {
    color: var(--color-text-2);
    font-size: 0.9rem;
    margin: 0;
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .topic-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1.375rem;
    text-decoration: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.1s ease;
  }

  .topic-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 16px rgba(91, 91, 214, 0.1);
    transform: translateY(-1px);
  }

  [data-theme="dark"] .topic-card:hover {
    box-shadow: 0 4px 16px rgba(129, 140, 248, 0.12);
  }

  .topic-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.25rem;
  }

  .topic-card__icon {
    font-size: 1.25rem;
    color: var(--color-accent);
  }

  .topic-card__count {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-text-3);
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.15em 0.6em;
  }

  .topic-card__name {
    font-size: 0.975rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .topic-card:hover .topic-card__name {
    color: var(--color-accent);
  }

  .topic-card__desc {
    font-size: 0.78rem;
    color: var(--color-text-2);
    margin: 0;
    line-height: 1.55;
    flex: 1;
  }

  .topic-card__badges {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  .topic-card__patterns {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.1rem;
  }

  .tag-extra {
    background: var(--color-surface-2);
    color: var(--color-text-3);
    font-size: 0.65rem;
  }

  @media (max-width: 480px) {
    .topics-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
