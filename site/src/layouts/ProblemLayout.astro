---
import BaseLayout from './BaseLayout.astro';

type NavItem = { title: string; slug: string } | null;

interface Props {
  title:          string;
  description?:   string;
  topic:          string;
  topicSlug:      string;
  difficulty:     'Easy' | 'Medium' | 'Hard';
  tags?:          string[];
  patterns?:      string[];
  timeComplexity?:  string;
  spaceComplexity?: string;
  leetcodeUrl?:   string;
  githubUrl?:     string;
  prev?:          NavItem;
  next?:          NavItem;
}

const {
  title,
  description,
  topic,
  topicSlug,
  difficulty,
  tags         = [],
  patterns     = [],
  timeComplexity,
  spaceComplexity,
  leetcodeUrl,
  githubUrl,
  prev         = null,
  next         = null,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={title} description={description ?? `${title} — Python solution with walkthrough`}>

  <!-- Breadcrumb -->
  <nav class="breadcrumb page-container" aria-label="Breadcrumb">
    <a href={`${base}/`}>Home</a>
    <span aria-hidden="true">›</span>
    <a href={`${base}/topics/${topicSlug}`}>{topic}</a>
    <span aria-hidden="true">›</span>
    <span aria-current="page">{title}</span>
  </nav>

  <div class="problem-page page-container">

    <!-- Sidebar -->
    <aside class="problem-sidebar" aria-label="Problem sidebar">
      <div class="sidebar-section">
        <a href={`${base}/topics/${topicSlug}`} class="back-link">← {topic}</a>
      </div>

      <div class="sidebar-section">
        <p class="sidebar-label">Difficulty</p>
        <span class:list={['badge', `badge-${difficulty.toLowerCase()}`]}>{difficulty}</span>
      </div>

      {tags.length > 0 && (
        <div class="sidebar-section">
          <p class="sidebar-label">Topics</p>
          <div class="tag-list">
            {tags.map(t => <span class="tag">{t}</span>)}
          </div>
        </div>
      )}

      {patterns.length > 0 && (
        <div class="sidebar-section">
          <p class="sidebar-label">Patterns</p>
          <div class="tag-list">
            {patterns.map(p => <span class="tag">{p}</span>)}
          </div>
        </div>
      )}

      {(timeComplexity || spaceComplexity) && (
        <div class="sidebar-section">
          <p class="sidebar-label">Complexity</p>
          <div class="complexity-block">
            {timeComplexity && (
              <div class="complexity-item">
                <span class="complexity-label">Time</span>
                <span class="complexity-value">{timeComplexity}</span>
              </div>
            )}
            {spaceComplexity && (
              <div class="complexity-item">
                <span class="complexity-label">Space</span>
                <span class="complexity-value">{spaceComplexity}</span>
              </div>
            )}
          </div>
        </div>
      )}

      <div class="sidebar-section">
        <p class="sidebar-label">Links</p>
        {leetcodeUrl && (
          <a href={leetcodeUrl} target="_blank" rel="noopener noreferrer" class="ext-link">
            LeetCode ↗
          </a>
        )}
        {githubUrl && (
          <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="ext-link">
            GitHub Source ↗
          </a>
        )}
      </div>
    </aside>

    <!-- Content -->
    <article class="problem-content prose">
      <h1>{title}</h1>
      <slot />
    </article>

  </div>

  <!-- Prev / Next navigation -->
  {(prev || next) && (
    <nav class="prevnext page-container" aria-label="Problem navigation">
      <div class="prevnext__slot prevnext__slot--prev">
        {prev && (
          <a href={`${base}/problems/${prev.slug}`} class="prevnext-link">
            <span class="prevnext-dir">← Previous</span>
            <span class="prevnext-title">{prev.title}</span>
          </a>
        )}
      </div>
      <a href={`${base}/topics/${topicSlug}`} class="prevnext-topic">{topic}</a>
      <div class="prevnext__slot prevnext__slot--next">
        {next && (
          <a href={`${base}/problems/${next.slug}`} class="prevnext-link prevnext-link--right">
            <span class="prevnext-dir">Next →</span>
            <span class="prevnext-title">{next.title}</span>
          </a>
        )}
      </div>
    </nav>
  )}

</BaseLayout>

<script>
  document.querySelectorAll<HTMLPreElement>('.problem-content pre').forEach(pre => {
    const btn = document.createElement('button');
    btn.className = 'copy-btn';
    btn.textContent = 'Copy';
    btn.setAttribute('aria-label', 'Copy code to clipboard');
    btn.addEventListener('click', async () => {
      const code = pre.querySelector('code')?.innerText ?? pre.innerText;
      await navigator.clipboard.writeText(code);
      btn.textContent = 'Copied!';
      btn.classList.add('copy-btn--done');
      setTimeout(() => {
        btn.textContent = 'Copy';
        btn.classList.remove('copy-btn--done');
      }, 2000);
    });
    pre.style.position = 'relative';
    pre.appendChild(btn);
  });
</script>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-top: 1.25rem;
    padding-bottom: 0.75rem;
    font-size: 0.8rem;
    color: var(--color-text-3);
    flex-wrap: wrap;
  }
  .breadcrumb a {
    color: var(--color-text-2);
    text-decoration: none;
  }
  .breadcrumb a:hover { color: var(--color-accent); }

  .problem-page {
    display: grid;
    grid-template-columns: var(--sidebar-width) 1fr;
    gap: 2.5rem;
    padding-top: 1rem;
    padding-bottom: 4rem;
    align-items: start;
  }

  /* Sidebar */
  .problem-sidebar {
    position: sticky;
    top: calc(var(--nav-height) + 1.25rem);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .sidebar-section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sidebar-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-3);
    margin: 0;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface-2);
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .back-link:hover {
    border-color: var(--color-accent);
    background: var(--color-accent-bg);
  }

  .ext-link {
    display: inline-block;
    font-size: 0.8rem;
    color: var(--color-accent);
    text-decoration: none;
    padding: 0.2rem 0;
  }
  .ext-link:hover { color: var(--color-accent-2); }

  /* ── Copy button ──────────────────────────────────────── */
  :global(.copy-btn) {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    font-size: 0.7rem;
    font-weight: 600;
    font-family: var(--font-sans, sans-serif);
    color: var(--color-text-2);
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0.2em 0.6em;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.15s ease, color 0.15s ease, background 0.15s ease;
    z-index: 1;
  }
  :global(pre:hover .copy-btn),
  :global(.copy-btn:focus) { opacity: 1; }
  :global(.copy-btn:hover) {
    color: var(--color-text);
    border-color: var(--color-border-2);
  }
  :global(.copy-btn--done) {
    opacity: 1;
    color: var(--color-easy) !important;
    border-color: var(--color-easy) !important;
  }

  /* ── Prev / Next bar ──────────────────────────────────── */
  .prevnext {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding-top: 1.5rem;
    padding-bottom: 3rem;
    border-top: 1px solid var(--color-border);
    margin-top: 0.5rem;
  }
  .prevnext__slot { display: flex; }
  .prevnext__slot--next { justify-content: flex-end; }

  .prevnext-link {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    max-width: 260px;
    text-decoration: none;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .prevnext-link:hover {
    border-color: var(--color-accent);
    box-shadow: 0 2px 8px rgba(91, 91, 214, 0.08);
  }
  .prevnext-link--right { text-align: right; }
  .prevnext-dir {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-3);
  }
  .prevnext-title {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
  }
  .prevnext-link:hover .prevnext-title { color: var(--color-accent); }

  .prevnext-topic {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-3);
    text-decoration: none;
    white-space: nowrap;
    text-align: center;
  }
  .prevnext-topic:hover { color: var(--color-accent); }

  /* Content */
  .problem-content h1 {
    font-size: 1.6rem;
    margin-top: 0;
    margin-bottom: 0.75rem;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .problem-page {
      grid-template-columns: 1fr;
    }
    .problem-sidebar {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 1rem;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      padding: 1rem 1.25rem;
    }
    .prevnext {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
    }
    .prevnext-topic {
      grid-column: 1 / -1;
      order: -1;
      text-align: center;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--color-border);
    }
    .prevnext-link { max-width: none; }
  }

  @media (max-width: 480px) {
    .prevnext {
      grid-template-columns: 1fr;
    }
    .prevnext__slot--next { justify-content: flex-start; }
    .prevnext-link--right { text-align: left; }
  }
</style>
