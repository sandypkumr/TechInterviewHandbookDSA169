---
import ThemeToggle from '../ui/ThemeToggle.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navLinks = [
  { href: `${base}/topics`,      label: 'Topics'      },
  { href: `${base}/patterns`,    label: 'Patterns'    },
  { href: `${base}/cheatsheets`, label: 'Cheat Sheets' },
  { href: `${base}/search`,      label: 'Search'      },
];

const currentPath = Astro.url.pathname;
---

<header class="navbar" role="banner">
  <div class="navbar__inner page-container">

    <!-- Logo -->
    <a href={`${base}/`} class="navbar__logo" aria-label="DSA Python — Home">
      <span class="navbar__logo-icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="32" height="32" rx="7" fill="var(--color-accent)"/>
          <text x="5" y="23" font-family="monospace" font-size="16" font-weight="700" fill="white">Py</text>
        </svg>
      </span>
      <span class="navbar__logo-text">DSA<span class="navbar__logo-accent">Python</span></span>
    </a>

    <!-- Desktop Nav -->
    <nav class="navbar__nav" aria-label="Main navigation">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={['navbar__link', { 'navbar__link--active': currentPath.startsWith(link.href) }]}
          aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Right Actions -->
    <div class="navbar__actions">
      <ThemeToggle />
      <button
        id="mobile-menu-btn"
        class="navbar__mobile-btn"
        aria-label="Toggle mobile menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-open-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6"  x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="menu-close-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" style="display:none">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="navbar__mobile-menu" role="navigation" aria-label="Mobile navigation" hidden>
    {navLinks.map(link => (
      <a
        href={link.href}
        class:list={['navbar__mobile-link', { 'navbar__mobile-link--active': currentPath.startsWith(link.href) }]}
        aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
      >
        {link.label}
      </a>
    ))}
  </div>
</header>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--nav-height);
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    background-color: color-mix(in srgb, var(--color-bg) 90%, transparent);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    height: 100%;
    gap: 1.5rem;
  }

  /* Logo */
  .navbar__logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .navbar__logo-text {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }
  .navbar__logo-accent {
    color: var(--color-accent);
  }
  .navbar__logo-icon {
    display: flex;
    align-items: center;
  }

  /* Desktop nav */
  .navbar__nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: 0.5rem;
    flex: 1;
  }
  .navbar__link {
    padding: 0.4rem 0.75rem;
    border-radius: var(--radius);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-2);
    text-decoration: none;
    transition: color 0.15s ease, background-color 0.15s ease;
    white-space: nowrap;
  }
  .navbar__link:hover {
    color: var(--color-text);
    background: var(--color-surface-2);
  }
  .navbar__link--active {
    color: var(--color-accent);
    background: var(--color-accent-bg);
  }

  /* Actions */
  .navbar__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
  }

  /* Mobile button */
  .navbar__mobile-btn {
    display: none;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-2);
    cursor: pointer;
    transition: background-color 0.15s ease;
  }
  .navbar__mobile-btn:hover {
    background: var(--color-surface-2);
  }

  /* Mobile menu */
  .navbar__mobile-menu {
    display: flex;
    flex-direction: column;
    padding: 0.75rem 1rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
    gap: 0.25rem;
  }
  .navbar__mobile-menu[hidden] { display: none; }

  .navbar__mobile-link {
    padding: 0.6rem 0.75rem;
    border-radius: var(--radius);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-2);
    text-decoration: none;
    transition: color 0.15s ease, background-color 0.15s ease;
  }
  .navbar__mobile-link:hover {
    color: var(--color-text);
    background: var(--color-surface-2);
  }
  .navbar__mobile-link--active {
    color: var(--color-accent);
    background: var(--color-accent-bg);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .navbar {
      height: auto;
      min-height: var(--nav-height);
    }
    .navbar__inner {
      height: var(--nav-height);
    }
    .navbar__nav {
      display: none;
    }
    .navbar__mobile-btn {
      display: flex;
    }
  }
</style>

<script>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const openIcon = document.getElementById('menu-open-icon');
    const closeIcon = document.getElementById('menu-close-icon');
    if (!btn || !menu) return;

    const closeMenu = () => {
      menu.hidden = true;
      btn.setAttribute('aria-expanded', 'false');
      if (openIcon)  openIcon.style.display  = 'block';
      if (closeIcon) closeIcon.style.display = 'none';
    };

    btn.addEventListener('click', () => {
      const isOpen = !menu.hidden;
      menu.hidden = isOpen;
      btn.setAttribute('aria-expanded', String(!isOpen));
      if (openIcon)  openIcon.style.display  = isOpen ? 'block' : 'none';
      if (closeIcon) closeIcon.style.display = isOpen ? 'none'  : 'block';
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.hidden) {
        closeMenu();
        btn.focus();
      }
    });
  }

  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>
